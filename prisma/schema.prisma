datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique // Nomor telepon jadi ID unik
  createdAt DateTime @default(now())
}
